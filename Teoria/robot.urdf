<robot name="ejercicio1">

  <material name="blue_link">
    <color rgba="0.0 0.35 0.9 1.0"/>
  </material>

  <material name="green_link">
    <color rgba="0.1 0.7 0.2 1.0"/>
  </material>

  <material name="orange_link">
    <color rgba="0.95 0.5 0.05 1.0"/>
  </material>

  <material name="yellow_link">
    <color rgba="0.95 0.8 0.10 1.0"/>
  </material>

  <material name="red_link">
    <color rgba="0.85 0.15 0.15 1.0"/>
  </material>

  <material name="dark_gray">
    <color rgba="0.25 0.25 0.25 1.0"/>
  </material>

  <!-- Base -->
  <link name="link0_passive">
    <visual>
      <geometry>
        <cylinder length="0.10" radius="0.12"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
  </link>

  <!-- Eslabon 1: columna vertical -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 1.0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="2.0" radius="0.07"/>
      </geometry>
      <material name="blue_link"/>
    </visual>
  </link>

  <joint name="q1" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="link0_passive"/>
    <child link="link1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="2"/>
  </joint>

  <!-- Eslabon 2: carro prismático -->
  <link name="link2">
    <visual>
      <origin xyz="0 0 0.20" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.40" radius="0.09"/>
      </geometry>
      <material name="green_link"/>
    </visual>
  </link>

  <joint name="q2" type="prismatic">
    <origin xyz="0 0 2.0" rpy="0 0 0"/>
    <parent link="link1"/>
    <child link="link2"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="1.0" effort="10" velocity="1"/>
  </joint>

  <!-- Eslabon 3 -->
  <link name="link3">
    <visual>
      <origin xyz="1.0 0 0" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder length="2.0" radius="0.05"/>
      </geometry>
      <material name="orange_link"/>
    </visual>
  </link>

  <joint name="q3" type="revolute">
    <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
    <parent link="link2"/>
    <child link="link3"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="2"/>
  </joint>

  <!-- Eslabon 4 -->
  <link name="link4">
    <visual>
      <origin xyz="1.0 0 0" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder length="2.0" radius="0.05"/>
      </geometry>
      <material name="yellow_link"/>
    </visual>
  </link>

  <joint name="q4" type="revolute">
    <origin xyz="2.0 0 0" rpy="0 0 0"/>
    <parent link="link3"/>
    <child link="link4"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="2"/>
  </joint>

  <!-- Eslabon 5 -->
  <link name="link5">
    <visual>
      <origin xyz="0.5 0 0" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder length="1.0" radius="0.05"/>
      </geometry>
      <material name="red_link"/>
    </visual>
  </link>

  <joint name="q5" type="revolute">
    <origin xyz="2.0 0 0" rpy="0 0 0"/>
    <parent link="link4"/>
    <child link="link5"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="2"/>
  </joint>

</robot>
